# Demo deployment for customer review
# Copy to .env.demo and adjust only the highlighted values.

MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=battery_platform
NEO4J_AUTH=neo4j/change_me_strong_password
NEO4J_PASSWORD=change_me_strong_password
REDIS_PASSWORD=change_me_redis_password
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change_me_strong_password
INFLUXDB_ORG=battery
INFLUXDB_BUCKET=battery_measure
INFLUXDB_ADMIN_TOKEN=change_me_influxdb_token
JWT_SECRET=change_me_jwt_secret_at_least_256_bits_long_for_hs256_algorithm
JWT_EXPIRATION=86400000
MYSQL_HOST_PORT=3306
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687
INFLUXDB_HOST_PORT=8086
REDIS_HOST_PORT=16379
MQTT_HOST_PORT=28884
GATEWAY_HOST_PORT=8080
API_SERVICE_HOST_PORT=8081
ALGORITHM_HOST_PORT=8000
API_SERVICE_URI=http://api-service:8081
ALGORITHM_SERVICE_URI=http://algorithm:8000
ALGORITHM_ENGINE_URL=http://algorithm:8000
ALGORITHM_ENGINE_API_KEY=change_me_algorithm_engine_api_key
AUTH_DEMO_ENABLED=true
AUTH_DEMO_USERNAME=demo_admin
AUTH_DEMO_PASSWORD=admin123
DEMO_DATA_ENABLED=true
ALGO_CORS_ORIGINS=https://battery.scdc.cloud,http://127.0.0.1:3010
ALGO_INTERNAL_API_KEY=change_me_internal_algo_api_key
ALGORITHM_BASE_URL=http://algorithm:8000
ALGORITHM_HOST=0.0.0.0
ALGORITHM_PORT=8000
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=bms/
MQTT_USERNAME=change_me_mqtt_user
MQTT_PASSWORD=change_me_mqtt_password
GATEWAY_CORS_ORIGINS=https://battery.scdc.cloud,http://127.0.0.1:3010
WEB_HOST_PORT=3010
