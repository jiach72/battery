# =============================================================
# Battery Platform - 环境变量配置模板
# =============================================================
# 使用方法：
#   cp .env.example .env
#   然后将所有 CHANGE_ME 替换为真实值
#
# ⚠️  .env 文件必须加入 .gitignore，严禁提交到版本仓库！
# =============================================================

# ====== MySQL 数据库 ======
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/battery_platform?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=battery_user
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ====== Neo4j ======
SPRING_NEO4J_URI=bolt://localhost:7687
SPRING_NEO4J_USERNAME=neo4j
SPRING_NEO4J_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ====== Redis ======
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# ====== Kafka ======
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ====== InfluxDB ======
INFLUXDB_URL=http://localhost:8086
# 生成 Token：influx auth create --org battery --read-buckets --write-buckets
INFLUXDB_TOKEN=CHANGE_ME_INFLUXDB_TOKEN
INFLUXDB_ORG=battery
INFLUXDB_BUCKET=battery_measure

# ====== 算法服务 ======
ALGORITHM_ENGINE_URL=http://algorithm:8000
ALGORITHM_ENGINE_API_KEY=CHANGE_ME_INTERNAL_ALGO_API_KEY

# ====== 演示登录（默认关闭，生产保持 false） ======
AUTH_DEMO_ENABLED=false
AUTH_DEMO_USERNAME=
AUTH_DEMO_PASSWORD=

# ====== 演示数据降级（生产必须保持 false）======
DEMO_DATA_ENABLED=false

# ====== JWT ======
# 生成强密钥（Linux/Mac）：openssl rand -base64 64
# 生成强密钥（PowerShell）：[Convert]::ToBase64String((1..64 | ForEach-Object { [byte](Get-Random -Max 256) }))
JWT_SECRET=CHANGE_ME_AT_LEAST_256_BIT_RANDOM_STRING_DO_NOT_USE_DEFAULT
JWT_EXPIRATION=86400000

# ====== 生产提醒 ======
# 生产环境请通过环境变量或 Secret 注入，不要使用这些默认值直接启动。
